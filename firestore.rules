rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own projects
    match /artifacts/{appId}/users/{userId}/projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Saved HTML catalog share-link metadata (owner only)
    match /artifacts/{appId}/users/{userId}/catalogLinks/{linkId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public short-link lookup: anyone with the code can read the long Storage URL (then browser redirects).
    // Create/delete only by the owning user (ownerUserId must match auth uid).
    match /catalog_short_links/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['url', 'ownerUserId', 'storagePath', 'createdAt'])
                    && request.resource.data.ownerUserId == request.auth.uid
                    && request.resource.data.url is string
                    && request.resource.data.storagePath is string
                    && request.resource.data.url.size() < 4000
                    && request.resource.data.storagePath.size() < 500
                    && code.size() >= 8
                    && code.size() <= 16;
      allow delete: if request.auth != null && resource.data.ownerUserId == request.auth.uid;
      allow update: if false;
    }

    // Saved seller / business profiles — owner only
    match /artifacts/{appId}/users/{userId}/sellerProfiles/{profileId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Archived (issued) invoices + their payments — owner only
    match /artifacts/{appId}/users/{userId}/invoiceArchive/{invoiceId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Customer inquiries (from the public HTML catalog)
    match /artifacts/{appId}/users/{userId}/inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasAny(['customer', 'items'])
                    && request.resource.data.size() < 30
                    && request.resource.data.get('items', []) is list
                    && request.resource.data.get('items', []).size() < 200;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Community posts — all authenticated users can read; owner creates/deletes; no edits by others
    match /artifacts/{appId}/communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.keys().hasAll(['title', 'authorId', 'authorEmail', 'category', 'createdAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() < 300;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.authorId == request.auth.uid
                    && request.resource.data.authorId == resource.data.authorId
                    && request.resource.data.authorEmail == resource.data.authorEmail
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.keys().hasAll(['title', 'body', 'category', 'attachments', 'authorId', 'authorEmail', 'createdAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() < 300;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
