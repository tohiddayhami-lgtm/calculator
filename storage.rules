rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public-read catalogs (anyone can open the share link). Only the owner can write.
    match /users/{userId}/catalogs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Community shared files — all authenticated users can read; any authenticated user can upload; no overwrite
    match /community/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 100 * 1024 * 1024;
      allow delete: if request.auth != null;
      allow update: if false;
    }
    // All other private files: only the owner can read/write
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Public form submission file uploads — anyone can upload (no auth required); owner reads via download URL
    match /publicFormSubmissions/{formKey}/{allPaths=**} {
      allow read: if true;
      // uploadBytes needs write (create alone is not always enough for anonymous clients)
      allow write: if request.resource != null && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
