rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public-read catalogs (anyone can open the share link). Only the owner can write.
    match /users/{userId}/catalogs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // All other private files: only the owner can read/write
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
